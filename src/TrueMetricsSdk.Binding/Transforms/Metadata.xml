<?xml version="1.0" encoding="utf-8"?>
<metadata>
  <!-- Remove common Android/Kotlin-generated types that cause duplicate/invalid binding output -->
  <remove-node path="/api/package[@name='kotlin']/class[@name='Metadata']" />

  <!-- The AAR bundles a shaded internal Sentry implementation (libs/sentry-shaded.jar).
       Those types are not part of the public TrueMetrics SDK API surface and can break binding compilation
       due to covariant return types in Java (e.g., JsonObjectWriter returning JsonObjectWriter while
       implementing ObjectWriter which returns ObjectWriter). Remove them entirely. -->
